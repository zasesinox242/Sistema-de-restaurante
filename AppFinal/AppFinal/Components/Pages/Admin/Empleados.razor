@page "/admin/empleados"
@using AppFinal.Models
@using AppFinal.Models.Enums
@inject NavigationManager Navigation
@inject AuthService AuthService
@inject EmpleadoService EmpleadoService
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PaginaProtegida RolRequerido="ADMIN">
    <div style="min-height:100vh; background:#f6f8fb; padding:32px 20px;">
        <div style="max-width:1250px; margin:0 auto;">

            <!-- Header -->
            <div style="display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:24px;">
                <div style="display:flex; align-items:flex-start; gap:14px;">
                    <button @onclick="Volver"
                            style="padding:12px 16px; background:white; border:1px solid #d1d5db; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer; color:#1f2937; box-shadow:0 4px 10px rgba(0,0,0,0.04);">
                        ← Volver
                    </button>

                    <div>
                        <p style="margin:0; font-size:13px; font-weight:700; letter-spacing:1px; color:#6b7280; text-transform:uppercase;">
                            Administración
                        </p>
                        <h1 style="margin:6px 0 4px; font-size:34px; font-weight:800; color:#111827;">
                            Gestión de Empleados
                        </h1>
                        <p style="margin:0; font-size:15px; color:#6b7280;">
                            Bienvenido, <span style="font-weight:700; color:#374151;">@nombreUsuario</span>
                        </p>
                    </div>
                </div>

                <button @onclick="CerrarSesion"
                        style="padding:12px 18px; background:#fff1f2; color:#be123c; border:1px solid #fecdd3; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer;">
                    Cerrar sesión
                </button>
            </div>

            <!-- Resumen -->
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:16px; margin-bottom:24px;">
                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Empleados registrados</p>
                    <p style="margin:0; font-size:30px; font-weight:800; color:#111827;">@empleados.Count</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Modo actual</p>
                    <p style="margin:0; font-size:18px; font-weight:800; color:#111827;">@(editando ? "Edición" : "Registro")</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Módulo</p>
                    <p style="margin:0; font-size:18px; font-weight:800; color:#111827;">Recursos Humanos</p>
                </div>
            </div>

            <!-- Contenido -->
            <div style="display:grid; grid-template-columns:1.1fr 1.6fr; gap:22px; align-items:start;">

                <!-- Formulario -->
                <div style="background:white; border:1px solid #e5e7eb; border-radius:22px; padding:24px; box-shadow:0 8px 24px rgba(15,23,42,0.05);">
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:18px;">
                        <span style="font-size:24px;">📝</span>
                        <h3 style="margin:0; font-size:22px; font-weight:800; color:#111827;">
                            @(editando ? "Editar Empleado" : "Nuevo Empleado")
                        </h3>
                    </div>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                        <div>
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Nombre</label>
                            <input @bind="empleadoForm.nombre"
                                   style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;" />
                        </div>

                        <div>
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Apellido</label>
                            <input @bind="empleadoForm.apellido"
                                   style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;" />
                        </div>

                        <div>
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Tipo de documento</label>
                            <select @bind="empleadoForm.tipoDocumento"
                                    style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;">
                                <option>DNI</option>
                                <option>Carnet</option>
                                <option>Pasaporte</option>
                            </select>
                        </div>

                        <div>
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Número de documento</label>
                            <input @bind="empleadoForm.numeroDocumento"
                                   style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;" />
                        </div>
                    </div>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:18px;">
                        <div>
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Estado</label>
                            <select @bind="empleadoForm.estado"
                                    style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;">
                                <option>Activo</option>
                                <option>Inactivo</option>
                            </select>
                        </div>

                        <div>
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Jornada</label>
                            <select @bind="jornadaSeleccionada"
                                    style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;">
                                <option value="">Seleccionar</option>
                                <option value="FULL_TIME">Full Time</option>
                                <option value="PART_TIME">Part Time</option>
                                <option value="FINES_DE_SEMANA">Fines de semana</option>
                            </select>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(mensaje))
                    {
                        <div style="padding:12px 14px; margin-bottom:16px; border-radius:12px; background-color:@(esError ? "#fff1f2" : "#f0fdf4"); color:@(esError ? "#be123c" : "#166534"); border:1px solid @(esError ? "#fecdd3" : "#bbf7d0"); font-size:14px; font-weight:600;">
                            @mensaje
                        </div>
                    }

                    <div style="display:flex; gap:10px; flex-wrap:wrap;">
                        <button @onclick="GuardarEmpleado"
                                style="padding:12px 18px; background:#171a35; color:white; border:none; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer; box-shadow:0 8px 18px rgba(23,26,53,0.18);">
                            @(editando ? "Actualizar empleado" : "Guardar empleado")
                        </button>

                        @if (editando)
                        {
                            <button @onclick="CancelarEdicion"
                                    style="padding:12px 18px; background:#f3f4f6; color:#374151; border:none; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer;">
                                Cancelar
                            </button>
                        }
                    </div>
                </div>

                <!-- Tabla -->
                <div style="background:white; border:1px solid #e5e7eb; border-radius:22px; padding:22px; box-shadow:0 8px 24px rgba(15,23,42,0.05);">
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:18px;">
                        <div>
                            <h3 style="margin:0; font-size:22px; font-weight:800; color:#111827;">Listado de Empleados</h3>
                            <p style="margin:6px 0 0; font-size:14px; color:#6b7280;">Visualiza y administra el personal registrado.</p>
                        </div>

                        <div style="padding:8px 12px; background:#f9fafb; border:1px solid #eef2f7; border-radius:999px; font-size:13px; font-weight:700; color:#374151;">
                            Total: @empleados.Count
                        </div>
                    </div>

                    <div style="overflow-x:auto;">
                        <table style="width:100%; border-collapse:collapse; min-width:860px;">
                            <thead>
                                <tr style="background:#f9fafb;">
                                    <th style="padding:14px 12px; text-align:left; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Código</th>
                                    <th style="padding:14px 12px; text-align:left; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Empleado</th>
                                    <th style="padding:14px 12px; text-align:left; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Documento</th>
                                    <th style="padding:14px 12px; text-align:left; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Estado</th>
                                    <th style="padding:14px 12px; text-align:left; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Jornada</th>
                                    <th style="padding:14px 12px; text-align:right; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (empleados == null || !empleados.Any())
                                {
                                    <tr>
                                        <td colspan="6" style="text-align:center; padding:48px 12px; color:#6b7280;">
                                            No hay empleados registrados
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var emp in empleados)
                                    {
                                        <tr style="border-top:1px solid #f3f4f6;">
                                            <td style="padding:16px 12px; font-weight:700; color:#111827;">
                                                #@emp.codigoEmpleado
                                            </td>

                                            <td style="padding:16px 12px;">
                                                <div style="display:flex; flex-direction:column;">
                                                    <span style="font-size:15px; font-weight:700; color:#111827;">@emp.nombre @emp.apellido</span>
                                                    <span style="font-size:13px; color:#6b7280;">Personal registrado</span>
                                                </div>
                                            </td>

                                            <td style="padding:16px 12px;">
                                                <div style="display:flex; flex-direction:column;">
                                                    <span style="font-size:14px; font-weight:700; color:#111827;">@emp.tipoDocumento</span>
                                                    <span style="font-size:13px; color:#6b7280;">@emp.numeroDocumento</span>
                                                </div>
                                            </td>

                                            <td style="padding:16px 12px;">
                                                <span style="@ObtenerEstiloEstado(emp.estado)">
                                                    @emp.estado
                                                </span>
                                            </td>

                                            <td style="padding:16px 12px;">
                                                <span style="@ObtenerEstiloJornada(emp.jornada?.ToString())">
                                                    @(string.IsNullOrWhiteSpace(emp.jornada?.ToString()) ? "Sin jornada" : FormatearJornada(emp.jornada!.ToString()))
                                                </span>
                                            </td>

                                            <td style="padding:16px 12px; text-align:right;">
                                                <button @onclick="() => EditarEmpleado(emp)"
                                                        style="margin-right:8px; padding:8px 12px; background:#171a35; color:white; border:none; border-radius:10px; font-size:13px; font-weight:700; cursor:pointer;">
                                                    Editar
                                                </button>
                                                <button @onclick="() => EliminarEmpleado(emp.codigoEmpleado!.Value)"
                                                        style="padding:8px 12px; background:#fff1f2; color:#be123c; border:1px solid #fecdd3; border-radius:10px; font-size:13px; font-weight:700; cursor:pointer;">
                                                    Eliminar
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</PaginaProtegida>

@code {
    private string nombreUsuario = "Usuario";
    private List<Empleado> empleados = new();
    private Empleado empleadoForm = new();
    private string jornadaSeleccionada = "";
    private bool editando = false;
    private string mensaje = "";
    private bool esError = false;
    private bool inicializado = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || inicializado)
            return;

        inicializado = true;

        nombreUsuario = await AuthService.ObtenerUsuario() ?? "Admin";
        await CargarEmpleados();
        StateHasChanged();
    }

    private async Task CargarEmpleados()
    {
        try
        {
            empleados = await EmpleadoService.GetEmpleadosAsync();
            Console.WriteLine($"Empleados cargados: {empleados.Count}");
        }
        catch (Exception ex)
        {
            mensaje = $"Error al cargar empleados: {ex.Message}";
            esError = true;
        }
    }

    private async Task GuardarEmpleado()
    {
        if (string.IsNullOrWhiteSpace(empleadoForm.nombre) || string.IsNullOrWhiteSpace(empleadoForm.apellido))
        {
            mensaje = "Nombre y apellido requeridos";
            esError = true;
            return;
        }

        if (!string.IsNullOrEmpty(jornadaSeleccionada))
            empleadoForm.jornada = Enum.Parse<Jornada>(jornadaSeleccionada);
        else
            empleadoForm.jornada = null;

        try
        {
            if (editando)
            {
                if (!empleadoForm.codigoEmpleado.HasValue)
                {
                    mensaje = "ID inválido";
                    esError = true;
                    return;
                }

                var ok = await EmpleadoService.UpdateEmpleadoAsync(empleadoForm.codigoEmpleado.Value, empleadoForm);

                if (ok)
                {
                    mensaje = "Empleado actualizado correctamente";
                    esError = false;
                    await CargarEmpleados();
                    CancelarEdicion();
                }
                else
                {
                    mensaje = "Error al actualizar";
                    esError = true;
                }
            }
            else
            {
                var nuevo = await EmpleadoService.CreateEmpleadoAsync(empleadoForm);

                if (nuevo != null)
                {
                    mensaje = "Empleado creado correctamente";
                    esError = false;
                    await CargarEmpleados();
                    empleadoForm = new Empleado();
                    jornadaSeleccionada = "";
                    StateHasChanged();
                }
                else
                {
                    mensaje = "Error al crear. Verifique documento duplicado.";
                    esError = true;
                }
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error: {ex.Message}";
            esError = true;
        }
    }

    private void EditarEmpleado(Empleado emp)
    {
        empleadoForm = new Empleado
        {
            codigoEmpleado = emp.codigoEmpleado,
            nombre = emp.nombre,
            apellido = emp.apellido,
            tipoDocumento = emp.tipoDocumento,
            numeroDocumento = emp.numeroDocumento,
            estado = emp.estado,
            jornada = emp.jornada
        };

        jornadaSeleccionada = emp.jornada?.ToString() ?? "";
        editando = true;
    }

    private void CancelarEdicion()
    {
        empleadoForm = new();
        jornadaSeleccionada = "";
        editando = false;
        mensaje = "";
    }

    private async Task EliminarEmpleado(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "¿Eliminar este empleado?"))
            return;

        var ok = await EmpleadoService.DeleteEmpleadoAsync(id);

        if (ok)
        {
            mensaje = "Empleado eliminado correctamente";
            esError = false;
            await CargarEmpleados();

            if (editando && empleadoForm.codigoEmpleado == id)
                CancelarEdicion();
        }
        else
        {
            mensaje = "Error al eliminar";
            esError = true;
        }
    }

    private string ObtenerEstiloEstado(string? estado)
    {
        if (string.Equals(estado, "Activo", StringComparison.OrdinalIgnoreCase))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#dcfce7; color:#15803d;";

        return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#fee2e2; color:#b91c1c;";
    }

    private string ObtenerEstiloJornada(string? jornada)
    {
        if (string.IsNullOrWhiteSpace(jornada))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#f3f4f6; color:#4b5563;";

        if (jornada == "FULL_TIME")
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#dbeafe; color:#1d4ed8;";

        if (jornada == "PART_TIME")
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#fef3c7; color:#b45309;";

        return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#ede9fe; color:#6d28d9;";
    }

    private string FormatearJornada(string jornada)
    {
        return jornada switch
        {
            "FULL_TIME" => "Full Time",
            "PART_TIME" => "Part Time",
            "FINES_DE_SEMANA" => "Fines de semana",
            _ => jornada
        };
    }

    private async Task CerrarSesion()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }

    private void Volver()
    {
        Navigation.NavigateTo("/admin/dashboard");
    }
}