@page "/chef/pedidos-pendientes"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AppFinal.Models
@using AppFinal.Services
@using System.Threading
@implements IDisposable
@inject PedidoMozoApiService PedidoMozoService
@inject NavigationManager Navigation
@inject AuthService AuthService

<PaginaProtegida RolRequerido="CHEF">

    <div style="min-height:100vh; background:linear-gradient(180deg, #f8fafc 0%, #f6f8fb 100%); padding:32px 20px;">
        <div style="max-width:1180px; margin:0 auto;">

            <!-- Header -->
            <div style="display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:24px;">
                <div>
                    <p style="margin:0; font-size:12px; font-weight:800; letter-spacing:1px; color:#6b7280; text-transform:uppercase;">
                        Panel Chef
                    </p>
                    <h1 style="margin:8px 0 4px; font-size:36px; font-weight:800; color:#0f172a;">
                        Pedidos Pendientes 👨‍🍳
                    </h1>
                    <p style="margin:0; font-size:15px; color:#64748b;">
                        Bienvenido, <span style="font-weight:700; color:#334155;">@usuario</span>. Supervisa y gestiona los pedidos en cocina.
                    </p>
                </div>

                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                    <button @onclick="CargarPedidos"
                            style="padding:12px 18px; background:white; color:#0f172a; border:1px solid #dbe1ea; border-radius:14px; font-size:14px; font-weight:700; cursor:pointer; box-shadow:0 8px 18px rgba(15,23,42,0.05);">
                        ↻ Actualizar
                    </button>

                    <button @onclick="CerrarSesion"
                            style="padding:12px 18px; background:#fff1f2; color:#be123c; border:1px solid #fecdd3; border-radius:14px; font-size:14px; font-weight:700; cursor:pointer;">
                        Cerrar sesión
                    </button>
                </div>
            </div>

            <!-- Resumen -->
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:16px; margin-bottom:24px;">
                <div style="background:white; border:1px solid #e5e7eb; border-radius:20px; padding:20px; box-shadow:0 10px 24px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Pedidos visibles</p>
                    <p style="margin:0; font-size:32px; font-weight:800; color:#0f172a;">@pedidos.Count</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:20px; padding:20px; box-shadow:0 10px 24px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">En preparación</p>
                    <p style="margin:0; font-size:32px; font-weight:800; color:#0f172a;">@TotalEnPreparacion</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:20px; padding:20px; box-shadow:0 10px 24px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Listos</p>
                    <p style="margin:0; font-size:32px; font-weight:800; color:#0f172a;">@TotalListos</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:20px; padding:20px; box-shadow:0 10px 24px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Actualización</p>
                    <p style="margin:0; font-size:16px; font-weight:800; color:#0f172a;">Automática cada 8 segundos</p>
                </div>
            </div>

            @if (cargando)
            {
                <div style="background:white; border:1px solid #e5e7eb; border-radius:24px; padding:60px 24px; text-align:center; box-shadow:0 10px 30px rgba(15,23,42,0.05);">
                    <div style="font-size:42px; margin-bottom:12px;">⏳</div>
                    <p style="margin:0; font-size:16px; font-weight:600; color:#64748b;">Cargando pedidos...</p>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(error))
            {
                <div style="background:#fff1f2; border:1px solid #fecdd3; color:#be123c; border-radius:20px; padding:18px 20px; box-shadow:0 8px 24px rgba(15,23,42,0.04);">
                    <strong>Error:</strong> @error
                </div>
            }
            else if (pedidos.Count == 0)
            {
                <div style="background:white; border:1px solid #e5e7eb; border-radius:24px; padding:60px 24px; text-align:center; box-shadow:0 10px 30px rgba(15,23,42,0.05);">
                    <div style="width:84px; height:84px; margin:0 auto 16px; border-radius:999px; background:#f8fafc; display:flex; align-items:center; justify-content:center; font-size:36px;">
                        🍽️
                    </div>
                    <p style="margin:0 0 8px; font-size:24px; font-weight:800; color:#0f172a;">No hay pedidos pendientes</p>
                    <p style="margin:0; font-size:14px; color:#64748b;">Cuando el mozo registre pedidos, aparecerán aquí automáticamente.</p>
                </div>
            }
            else
            {
                <div style="display:flex; flex-direction:column; gap:18px;">
                    @foreach (var p in pedidos)
                    {
                        <div style="background:white; border:1px solid #e5e7eb; border-radius:24px; padding:24px; box-shadow:0 10px 28px rgba(15,23,42,0.05);">
                            <div style="display:flex; justify-content:space-between; align-items:center; gap:20px; flex-wrap:wrap;">

                                <div style="display:flex; flex-direction:column; gap:16px; flex:1; min-width:300px;">
                                    <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
                                        <div style="width:50px; height:50px; border-radius:16px; background:#eef2ff; display:flex; align-items:center; justify-content:center; font-size:24px;">
                                            🧾
                                        </div>

                                        <div>
                                            <div style="font-size:24px; font-weight:800; color:#0f172a; line-height:1.1;">
                                                Pedido #@p.Id.ToString("000")
                                            </div>
                                            <div style="margin-top:6px;">
                                                <span style="@ObtenerEstiloEstado(p.Estado)">
                                                    @p.Estado
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(170px, 1fr)); gap:14px;">
                                        <div style="background:#f8fafc; border:1px solid #eef2f7; border-radius:16px; padding:14px;">
                                            <p style="margin:0; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Mesa</p>
                                            <p style="margin:6px 0 0; font-size:16px; font-weight:800; color:#0f172a;">@p.MesaNombre</p>
                                        </div>

                                        <div style="background:#f8fafc; border:1px solid #eef2f7; border-radius:16px; padding:14px;">
                                            <p style="margin:0; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Fecha</p>
                                            <p style="margin:6px 0 0; font-size:16px; font-weight:800; color:#0f172a;">@p.Fecha.ToString("dd/MM/yyyy HH:mm")</p>
                                        </div>

                                        <div style="background:#f8fafc; border:1px solid #eef2f7; border-radius:16px; padding:14px;">
                                            <p style="margin:0; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Items</p>
                                            <p style="margin:6px 0 0; font-size:16px; font-weight:800; color:#0f172a;">@p.Items.Count item(s)</p>
                                        </div>
                                    </div>
                                </div>

                                <div style="display:flex; flex-direction:column; align-items:flex-end; justify-content:center; gap:12px; min-width:190px;">
                                    <div style="padding:10px 14px; background:#f8fafc; border:1px solid #eef2f7; border-radius:999px; font-size:13px; font-weight:700; color:#475569;">
                                        Ver detalle y actualizar flujo
                                    </div>

                                    <button @onclick="() => VerDetalle(p.Id)"
                                            style="padding:13px 20px; background:#171a35; color:white; border:none; border-radius:14px; font-size:14px; font-weight:700; cursor:pointer; min-width:155px; box-shadow:0 10px 22px rgba(23,26,53,0.18);">
                                        Ver detalle
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

        </div>
    </div>

</PaginaProtegida>

@code {
    private List<PedidoMozoDto> pedidos = new();
    private bool cargando = true;
    private bool inicializado = false;
    private bool recargando = false;
    private string usuario = "";
    private string error = "";
    private Timer? timer;

    private int TotalEnPreparacion =>
        pedidos.Count(p => p.Estado.Equals("En Preparación", StringComparison.OrdinalIgnoreCase));

    private int TotalListos =>
        pedidos.Count(p => p.Estado.Equals("Listo", StringComparison.OrdinalIgnoreCase));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || inicializado)
            return;

        inicializado = true;

        usuario = await AuthService.ObtenerUsuario() ?? "Chef";
        await CargarPedidos();
        IniciarAutoRefresh();
        StateHasChanged();
    }

    private void IniciarAutoRefresh()
    {
        timer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await CargarPedidosSilencioso();
            });
        }, null, TimeSpan.FromSeconds(8), TimeSpan.FromSeconds(8));
    }

    private async Task CargarPedidos()
    {
        if (recargando)
            return;

        recargando = true;
        cargando = true;
        error = "";

        try
        {
            pedidos = await PedidoMozoService.ObtenerPedidosChefAsync();
        }
        catch (Exception ex)
        {
            error = "Error al obtener pedidos: " + ex.Message;
        }
        finally
        {
            cargando = false;
            recargando = false;
            StateHasChanged();
        }
    }

    private async Task CargarPedidosSilencioso()
    {
        if (recargando)
            return;

        recargando = true;

        try
        {
            pedidos = await PedidoMozoService.ObtenerPedidosChefAsync();
        }
        catch
        {
        }
        finally
        {
            recargando = false;
            StateHasChanged();
        }
    }

    private string ObtenerEstiloEstado(string estado)
    {
        if (estado.Equals("En Espera", StringComparison.OrdinalIgnoreCase))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#fef3c7; color:#b45309;";

        if (estado.Equals("En Preparación", StringComparison.OrdinalIgnoreCase))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#dbeafe; color:#1d4ed8;";

        if (estado.Equals("Listo", StringComparison.OrdinalIgnoreCase))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#dcfce7; color:#15803d;";

        if (estado.Equals("Entregado", StringComparison.OrdinalIgnoreCase))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#e5e7eb; color:#374151;";

        return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#f3f4f6; color:#4b5563;";
    }

    private void VerDetalle(int id)
    {
        Navigation.NavigateTo($"/chef/detalle-pedido/{id}");
    }

    private async Task CerrarSesion()
    {
        timer?.Dispose();
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}