@page "/chef/detalle-pedido/{id:int}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using AppFinal.Models
@using AppFinal.Services
@inject PedidoMozoApiService PedidoMozoService
@inject NavigationManager Navigation
@inject AuthService AuthService

<PaginaProtegida RolRequerido="CHEF">

    <div style="min-height:100vh; background:linear-gradient(180deg, #f8fafc 0%, #f6f8fb 100%); padding:32px 20px;">
        <div style="max-width:1180px; margin:0 auto;">

            <!-- Header -->
            <div style="display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:24px;">
                <div style="display:flex; align-items:flex-start; gap:14px;">
                    <button @onclick="Volver"
                            style="padding:12px 16px; background:white; border:1px solid #dbe1ea; border-radius:14px; font-size:14px; font-weight:700; cursor:pointer; color:#1f2937; box-shadow:0 8px 18px rgba(15,23,42,0.05);">
                        ← Volver
                    </button>

                    <div>
                        <p style="margin:0; font-size:12px; font-weight:800; letter-spacing:1px; color:#6b7280; text-transform:uppercase;">
                            Panel Chef
                        </p>
                        <h1 style="margin:8px 0 4px; font-size:36px; font-weight:800; color:#0f172a;">
                            Detalle del Pedido
                        </h1>
                        <p style="margin:0; font-size:15px; color:#64748b;">
                            Visualiza el pedido y controla su flujo operativo en cocina.
                        </p>
                    </div>
                </div>
            </div>

            @if (cargando)
            {
                <div style="background:white; border:1px solid #e5e7eb; border-radius:24px; padding:60px 24px; text-align:center; box-shadow:0 10px 30px rgba(15,23,42,0.05);">
                    <div style="font-size:42px; margin-bottom:12px;">⏳</div>
                    <p style="margin:0; font-size:16px; font-weight:600; color:#64748b;">Cargando detalle del pedido...</p>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(error))
            {
                <div style="background:#fff1f2; border:1px solid #fecdd3; color:#be123c; border-radius:20px; padding:18px 20px; box-shadow:0 8px 24px rgba(15,23,42,0.04);">
                    <strong>Error:</strong> @error
                </div>
            }
            else if (pedido == null)
            {
                <div style="background:white; border:1px solid #e5e7eb; border-radius:24px; padding:60px 24px; text-align:center; box-shadow:0 10px 30px rgba(15,23,42,0.05);">
                    <div style="font-size:42px; margin-bottom:12px;">📭</div>
                    <p style="margin:0; font-size:22px; font-weight:800; color:#111827;">No se encontró el pedido</p>
                </div>
            }
            else
            {
                <div style="display:grid; grid-template-columns:minmax(0, 2fr) minmax(290px, 1fr); gap:22px; align-items:start;">

                    <!-- Columna izquierda -->
                    <div style="display:flex; flex-direction:column; gap:20px; min-width:0;">

                        <!-- Resumen -->
                        <div style="background:white; border:1px solid #e5e7eb; border-radius:24px; padding:26px; box-shadow:0 10px 30px rgba(15,23,42,0.05);">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:16px; flex-wrap:wrap;">
                                <div>
                                    <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:12px;">
                                        <div style="width:52px; height:52px; border-radius:16px; background:#eef2ff; display:flex; align-items:center; justify-content:center; font-size:26px;">
                                            🧾
                                        </div>

                                        <div>
                                            <div style="font-size:28px; font-weight:800; color:#0f172a; line-height:1.1;">
                                                Pedido #@pedido.Id.ToString("000")
                                            </div>
                                            <div style="margin-top:4px;">
                                                <span style="@ObtenerEstiloEstado(pedido.Estado)">
                                                    @pedido.Estado
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <p style="margin:0; font-size:14px; color:#64748b;">
                                        Información operativa del pedido seleccionado.
                                    </p>
                                </div>
                            </div>

                            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:14px; margin-top:22px;">
                                <div style="background:#f8fafc; border:1px solid #eef2f7; border-radius:16px; padding:16px;">
                                    <p style="margin:0; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Mesa</p>
                                    <p style="margin:7px 0 0; font-size:18px; font-weight:800; color:#0f172a;">@pedido.MesaNombre</p>
                                </div>

                                <div style="background:#f8fafc; border:1px solid #eef2f7; border-radius:16px; padding:16px;">
                                    <p style="margin:0; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Items</p>
                                    <p style="margin:7px 0 0; font-size:18px; font-weight:800; color:#0f172a;">@pedido.Items.Count item(s)</p>
                                </div>

                                <div style="background:#f8fafc; border:1px solid #eef2f7; border-radius:16px; padding:16px;">
                                    <p style="margin:0; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Comentarios</p>
                                    <p style="margin:7px 0 0; font-size:14px; color:#475569; line-height:1.5;">
                                        @(string.IsNullOrWhiteSpace(pedido.Comentarios) ? "Sin comentarios" : pedido.Comentarios)
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Items -->
                        <div style="background:white; border:1px solid #e5e7eb; border-radius:24px; padding:26px; box-shadow:0 10px 30px rgba(15,23,42,0.05);">
                            <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:18px;">
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div style="width:46px; height:46px; border-radius:14px; background:#fff7ed; display:flex; align-items:center; justify-content:center; font-size:24px;">
                                        🍽️
                                    </div>
                                    <div>
                                        <h3 style="margin:0; font-size:22px; font-weight:800; color:#0f172a;">Items del pedido</h3>
                                        <p style="margin:4px 0 0; font-size:14px; color:#64748b;">Detalle de productos y cantidades solicitadas.</p>
                                    </div>
                                </div>

                                <div style="padding:8px 12px; background:#f8fafc; border:1px solid #eef2f7; border-radius:999px; font-size:13px; font-weight:700; color:#334155;">
                                    Total items: @pedido.Items.Count
                                </div>
                            </div>

                            @if (pedido.Items != null && pedido.Items.Any())
                            {
                                <div style="display:flex; flex-direction:column; gap:12px;">
                                    @foreach (var item in pedido.Items)
                                    {
                                        <div style="display:flex; justify-content:space-between; align-items:center; gap:16px; padding:16px 0; border-bottom:1px solid #f1f5f9; flex-wrap:wrap;">
                                            <div style="display:flex; align-items:center; gap:14px;">
                                                <div style="width:42px; height:42px; border-radius:12px; background:#f8fafc; display:flex; align-items:center; justify-content:center; font-size:20px;">
                                                    🍴
                                                </div>
                                                <div>
                                                    <p style="margin:0; font-size:17px; font-weight:700; color:#0f172a;">@item.Nombre</p>
                                                    <p style="margin:5px 0 0; font-size:13px; color:#64748b;">
                                                        Cantidad solicitada: @item.Cantidad
                                                    </p>
                                                </div>
                                            </div>

                                            <div style="text-align:right;">
                                                <p style="margin:0; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Subtotal</p>
                                                <p style="margin:5px 0 0; font-size:19px; font-weight:800; color:#0f172a;">
                                                    S/ @item.SubTotal.ToString("0.00")
                                                </p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p style="margin:0; font-size:14px; color:#64748b;">No hay items en este pedido.</p>
                            }
                        </div>
                    </div>

                    <!-- Columna derecha -->
                    <div style="min-width:280px;">
                        <div style="background:white; border:1px solid #e5e7eb; border-radius:24px; padding:24px; box-shadow:0 10px 30px rgba(15,23,42,0.05); position:sticky; top:24px;">
                            <div style="display:flex; align-items:center; gap:10px; margin-bottom:18px;">
                                <div style="width:46px; height:46px; border-radius:14px; background:#ecfeff; display:flex; align-items:center; justify-content:center; font-size:24px;">
                                    ⚙️
                                </div>
                                <div>
                                    <h3 style="margin:0; font-size:22px; font-weight:800; color:#0f172a;">Acciones</h3>
                                    <p style="margin:4px 0 0; font-size:14px; color:#64748b;">Actualiza el flujo del pedido.</p>
                                </div>
                            </div>

                            <div style="display:flex; flex-direction:column; gap:12px;">
                                <button @onclick='() => CambiarEstado("En preparación")'
                                        disabled="@(!PuedePreparar || guardando)"
                                        style="@ObtenerEstiloBoton(PuedePreparar && !guardando, "#2563eb")">
                                    Preparando
                                </button>

                                <button @onclick='() => CambiarEstado("Listo")'
                                        disabled="@(!PuedeMarcarListo || guardando)"
                                        style="@ObtenerEstiloBoton(PuedeMarcarListo && !guardando, "#16a34a")">
                                    Listo
                                </button>

                                <button @onclick='() => CambiarEstado("Entregado")'
                                        disabled="@(!PuedeEntregar || guardando)"
                                        style="@ObtenerEstiloBoton(PuedeEntregar && !guardando, "#374151")">
                                    Entregado
                                </button>
                            </div>

                            <div style="margin-top:20px; padding:16px; background:#f8fafc; border:1px solid #eef2f7; border-radius:16px;">
                                <p style="margin:0; font-size:12px; color:#94a3b8; text-transform:uppercase; letter-spacing:0.8px;">Flujo del pedido</p>
                                <p style="margin:8px 0 0; font-size:14px; font-weight:600; color:#475569; line-height:1.7;">
                                    En Espera → En Preparación → Listo → Entregado
                                </p>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(mensaje))
                            {
                                <div style="margin-top:18px; padding:13px 14px; background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; border-radius:14px; font-size:14px; font-weight:700;">
                                    @mensaje
                                </div>
                            }
                        </div>
                    </div>

                </div>
            }

        </div>
    </div>

</PaginaProtegida>

@code {
    [Parameter] public int id { get; set; }

    private PedidoMozoDto? pedido;
    private bool cargando = true;
    private bool inicializado = false;
    private bool guardando = false;
    private string error = "";
    private string mensaje = "";

    private bool PuedePreparar =>
        pedido != null &&
        pedido.Estado.Equals("En Espera", StringComparison.OrdinalIgnoreCase);

    private bool PuedeMarcarListo =>
        pedido != null &&
        pedido.Estado.Equals("En Preparación", StringComparison.OrdinalIgnoreCase);

    private bool PuedeEntregar =>
        pedido != null &&
        pedido.Estado.Equals("Listo", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || inicializado)
            return;

        inicializado = true;

        try
        {
            pedido = await PedidoMozoService.ObtenerPedidoChefPorIdAsync(id);
        }
        catch (Exception ex)
        {
            error = "Error al cargar el detalle: " + ex.Message;
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CambiarEstado(string nuevoEstado)
    {
        if (pedido == null || guardando)
            return;

        if (pedido.Estado.Equals("En Espera", StringComparison.OrdinalIgnoreCase) &&
            nuevoEstado != "En preparación")
            return;

        if (pedido.Estado.Equals("En Preparación", StringComparison.OrdinalIgnoreCase) &&
            nuevoEstado != "Listo")
            return;

        if (pedido.Estado.Equals("Listo", StringComparison.OrdinalIgnoreCase) &&
            nuevoEstado != "Entregado")
            return;

        if (pedido.Estado.Equals("Entregado", StringComparison.OrdinalIgnoreCase))
            return;

        guardando = true;
        error = "";
        mensaje = "";

        try
        {
            pedido.Estado = nuevoEstado;
            mensaje = ObtenerMensajeEstado(nuevoEstado);
            StateHasChanged();

            await PedidoMozoService.ActualizarEstadoPedidoAsync(pedido.Id, nuevoEstado);
        }
        catch
        {
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }

    private string ObtenerMensajeEstado(string estado)
    {
        return estado switch
        {
            "En preparación" => "Pedido en preparación.",
            "Listo" => "Pedido listo.",
            "Entregado" => "Pedido entregado.",
            _ => "Estado actualizado correctamente."
        };
    }

    private string ObtenerEstiloEstado(string estado)
    {
        if (estado.Equals("En Espera", StringComparison.OrdinalIgnoreCase))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#fef3c7; color:#b45309;";

        if (estado.Equals("En Preparación", StringComparison.OrdinalIgnoreCase))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#dbeafe; color:#1d4ed8;";

        if (estado.Equals("Listo", StringComparison.OrdinalIgnoreCase))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#dcfce7; color:#15803d;";

        if (estado.Equals("Entregado", StringComparison.OrdinalIgnoreCase))
            return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#e5e7eb; color:#374151;";

        return "font-size:12px; font-weight:700; padding:7px 12px; border-radius:999px; background:#f3f4f6; color:#4b5563;";
    }

    private string ObtenerEstiloBoton(bool habilitado, string color)
    {
        if (!habilitado)
        {
            return "width:100%; padding:14px 16px; background:#e5e7eb; color:#9ca3af; border:none; border-radius:14px; font-size:14px; font-weight:700; cursor:not-allowed;";
        }

        return $"width:100%; padding:14px 16px; background:{color}; color:white; border:none; border-radius:14px; font-size:14px; font-weight:700; cursor:pointer; box-shadow:0 10px 20px rgba(0,0,0,0.10);";
    }

    private void Volver()
    {
        Navigation.NavigateTo("/chef/pedidos-pendientes");
    }
}