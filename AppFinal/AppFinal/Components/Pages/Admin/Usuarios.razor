@page "/admin/usuarios"
@using AppFinal.Models
@inject NavigationManager Navigation
@inject AuthService AuthService
@inject AppFinal.Services.JhiUserService UserService
@inject EmpleadoService EmpleadoService
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PaginaProtegida RolRequerido="ADMIN">
    <div style="min-height:100vh; background:#f6f8fb; padding:32px 20px;">
        <div style="max-width:1280px; margin:0 auto;">

            <!-- Header -->
            <div style="display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:24px;">
                <div style="display:flex; align-items:flex-start; gap:14px;">
                    <button @onclick="Volver"
                            style="padding:12px 16px; background:white; border:1px solid #d1d5db; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer; color:#1f2937; box-shadow:0 4px 10px rgba(0,0,0,0.04);">
                        ← Volver
                    </button>

                    <div>
                        <p style="margin:0; font-size:13px; font-weight:700; letter-spacing:1px; color:#6b7280; text-transform:uppercase;">
                            Administración
                        </p>
                        <h1 style="margin:6px 0 4px; font-size:34px; font-weight:800; color:#111827;">
                            Gestión de Usuarios
                        </h1>
                        <p style="margin:0; font-size:15px; color:#6b7280;">
                            Bienvenido, <span style="font-weight:700; color:#374151;">@nombreUsuario</span>
                        </p>
                    </div>
                </div>

                <button @onclick="CerrarSesion"
                        style="padding:12px 18px; background:#fff1f2; color:#be123c; border:1px solid #fecdd3; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer;">
                    Cerrar sesión
                </button>
            </div>

            <!-- Resumen -->
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:16px; margin-bottom:24px;">
                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Usuarios registrados</p>
                    <p style="margin:0; font-size:30px; font-weight:800; color:#111827;">@usuarios.Count</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Empleados vinculables</p>
                    <p style="margin:0; font-size:30px; font-weight:800; color:#111827;">@empleadosDisponibles.Count</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Modo actual</p>
                    <p style="margin:0; font-size:18px; font-weight:800; color:#111827;">@(editando ? "Edición" : "Registro")</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Seguridad</p>
                    <p style="margin:0; font-size:18px; font-weight:800; color:#111827;">Roles y accesos</p>
                </div>
            </div>

            <!-- Contenido -->
            <div style="display:grid; grid-template-columns:1.05fr 1.7fr; gap:22px; align-items:start;">

                <!-- Formulario -->
                <div style="background:white; border:1px solid #e5e7eb; border-radius:22px; padding:24px; box-shadow:0 8px 24px rgba(15,23,42,0.05);">
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:18px;">
                        <span style="font-size:24px;">👤</span>
                        <h3 style="margin:0; font-size:22px; font-weight:800; color:#111827;">
                            @(editando ? "Editar Usuario" : "Nuevo Usuario")
                        </h3>
                    </div>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                        <div>
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Nombre de usuario</label>
                            <input @bind="userForm.login"
                                   placeholder="Login"
                                   disabled="@editando"
                                   style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box; background:@(editando ? "#f9fafb" : "white");" />
                        </div>

                        <div>
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Email</label>
                            <input @bind="userForm.email"
                                   placeholder="Email"
                                   style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;" />
                        </div>

                        @if (!editando)
                        {
                            <div>
                                <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Contraseña</label>
                                <input type="password"
                                       @bind="userForm.password"
                                       placeholder="Contraseña"
                                       style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;" />
                            </div>
                        }

                        <div>
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Rol</label>
                            <select @bind="rolSeleccionado"
                                    style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;">
                                <option value="ROLE_ADMIN">Administrador</option>
                                <option value="ROLE_CHEF">Chef</option>
                                <option value="ROLE_MOZO">Mozo</option>
                            </select>
                        </div>

                        <div style="grid-column: span 2;">
                            <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Empleado vinculado</label>
                            <select @bind="empleadoSeleccionadoId"
                                    style="width:100%; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;">
                                <option value="">Sin empleado</option>
                                @foreach (var emp in empleadosDisponibles)
                                {
                                    <option value="@emp.codigoEmpleado">@emp.nombre @emp.apellido</option>
                                }
                            </select>
                        </div>

                        @if (editando)
                        {
                            <div style="grid-column: span 2;">
                                <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:#4b5563;">Cambiar contraseña</label>
                                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                                    <input type="password"
                                           @bind="nuevaPassword"
                                           placeholder="Nueva contraseña"
                                           style="flex:1; min-width:220px; padding:12px 14px; border:1px solid #d1d5db; border-radius:12px; font-size:14px; box-sizing:border-box;" />
                                    <button @onclick="CambiarPassword"
                                            style="padding:12px 16px; background:#171a35; color:white; border:none; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer;">
                                        Cambiar
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(mensaje))
                    {
                        <div style="padding:12px 14px; margin-bottom:16px; border-radius:12px; background-color:@(esError ? "#fff1f2" : "#f0fdf4"); color:@(esError ? "#be123c" : "#166534"); border:1px solid @(esError ? "#fecdd3" : "#bbf7d0"); font-size:14px; font-weight:600;">
                            @mensaje
                        </div>
                    }

                    <div style="display:flex; gap:10px; flex-wrap:wrap;">
                        <button @onclick="GuardarUsuario"
                                style="padding:12px 18px; background:#171a35; color:white; border:none; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer; box-shadow:0 8px 18px rgba(23,26,53,0.18);">
                            @(editando ? "Actualizar usuario" : "Guardar usuario")
                        </button>

                        @if (editando)
                        {
                            <button @onclick="CancelarEdicion"
                                    style="padding:12px 18px; background:#f3f4f6; color:#374151; border:none; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer;">
                                Cancelar
                            </button>
                        }
                    </div>
                </div>

                <!-- Tabla -->
                <div style="background:white; border:1px solid #e5e7eb; border-radius:22px; padding:22px; box-shadow:0 8px 24px rgba(15,23,42,0.05);">
                    <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:18px;">
                        <div>
                            <h3 style="margin:0; font-size:22px; font-weight:800; color:#111827;">Usuarios del Sistema</h3>
                            <p style="margin:6px 0 0; font-size:14px; color:#6b7280;">Gestiona credenciales, roles y vinculación con empleados.</p>
                        </div>

                        <div style="padding:8px 12px; background:#f9fafb; border:1px solid #eef2f7; border-radius:999px; font-size:13px; font-weight:700; color:#374151;">
                            Total: @usuarios.Count
                        </div>
                    </div>

                    @if (cargando)
                    {
                        <div style="text-align:center; padding:48px 12px; color:#6b7280;">
                            Cargando usuarios...
                        </div>
                    }
                    else if (usuarios == null || !usuarios.Any())
                    {
                        <div style="text-align:center; padding:48px 12px; color:#6b7280;">
                            No hay usuarios registrados
                        </div>
                    }
                    else
                    {
                        <div style="overflow-x:auto;">
                            <table style="width:100%; border-collapse:collapse; min-width:950px;">
                                <thead>
                                    <tr style="background:#f9fafb;">
                                        <th style="padding:14px 12px; text-align:left; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Usuario</th>
                                        <th style="padding:14px 12px; text-align:left; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Email</th>
                                        <th style="padding:14px 12px; text-align:left; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Rol</th>
                                        <th style="padding:14px 12px; text-align:left; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Empleado</th>
                                        <th style="padding:14px 12px; text-align:right; font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px;">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var u in usuarios)
                                    {
                                        var empleadoAsociado = empleados.FirstOrDefault(e => e.usuarioId == u.id);
                                        var rol = u.authorities.FirstOrDefault() ?? "ROLE_ADMIN";

                                        <tr style="border-top:1px solid #f3f4f6;">
                                            <td style="padding:16px 12px;">
                                                <div style="display:flex; flex-direction:column;">
                                                    <span style="font-size:15px; font-weight:700; color:#111827;">@u.login</span>
                                                    <span style="font-size:13px; color:#6b7280;">Cuenta registrada</span>
                                                </div>
                                            </td>

                                            <td style="padding:16px 12px;">
                                                <span style="font-size:14px; color:#111827;">@u.email</span>
                                            </td>

                                            <td style="padding:16px 12px;">
                                                <span style="@ObtenerEstiloRol(rol)">
                                                    @FormatearRol(rol)
                                                </span>
                                            </td>

                                            <td style="padding:16px 12px;">
                                                @if (empleadoAsociado != null)
                                                {
                                                    <div style="display:flex; flex-direction:column;">
                                                        <span style="font-size:14px; font-weight:700; color:#111827;">@empleadoAsociado.nombre @empleadoAsociado.apellido</span>
                                                        <span style="font-size:13px; color:#6b7280;">Código: @empleadoAsociado.codigoEmpleado</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span style="font-size:13px; font-weight:700; padding:7px 12px; border-radius:999px; background:#f3f4f6; color:#4b5563;">
                                                        Sin empleado
                                                    </span>
                                                }
                                            </td>

                                            <td style="padding:16px 12px; text-align:right;">
                                                <button @onclick="() => EditarUsuario(u)"
                                                        style="margin-right:8px; padding:8px 12px; background:#171a35; color:white; border:none; border-radius:10px; font-size:13px; font-weight:700; cursor:pointer;">
                                                    Editar
                                                </button>
                                                <button @onclick="() => EliminarUsuario(u.login)"
                                                        style="padding:8px 12px; background:#fff1f2; color:#be123c; border:1px solid #fecdd3; border-radius:10px; font-size:13px; font-weight:700; cursor:pointer;">
                                                    Eliminar
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</PaginaProtegida>

@code {
    // Nombre del usuario que se mostrará arriba
    private string nombreUsuario = "Usuario";

    // Lista de usuarios del sistema
    private List<JhiUser> usuarios = new();

    // Lista de empleados
    private List<Empleado> empleados = new();

    // Lista de empleados disponibles para vincular a un usuario
    private List<Empleado> empleadosDisponibles =>
        empleados.Where(e => !e.usuarioId.HasValue || (editando && e.usuarioId == usuarioEditando?.id)).ToList();

    // Formulario donde se guardan los datos del usuario
    private JhiUserCreateDto userForm = new();

    // Rol seleccionado (ADMIN por defecto)
    private string rolSeleccionado = "ROLE_ADMIN";

    // ID del empleado seleccionado
    private int? empleadoSeleccionadoId = null;

    // Indica si estamos editando o creando
    private bool editando = false;

    // Usuario que se está editando
    private JhiUser? usuarioEditando = null;

    // Nueva contraseña (solo cuando se edita)
    private string nuevaPassword = "";

    // Mensaje que se muestra al usuario
    private string mensaje = "";

    // Indica si el mensaje es error
    private bool esError = false;

    // Indica si está cargando datos
    private bool cargando = true;

    // Evita que se ejecute varias veces
    private bool inicializado = false;

    // Se ejecuta después de cargar la página
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Solo se ejecuta una vez
        if (!firstRender || inicializado)
            return;

        inicializado = true;

        // Obtiene nombre del usuario
        nombreUsuario = await AuthService.ObtenerUsuario() ?? "Admin";

        // Carga datos
        await CargarEmpleados();
        await CargarUsuarios();

        cargando = false;

        // Actualiza la pantalla
        StateHasChanged();
    }

    // Carga la lista de empleados
    private async Task CargarEmpleados()
    {
        try
        {
            empleados = await EmpleadoService.GetEmpleadosAsync();

            // Muestra datos en consola (para pruebas)
            Console.WriteLine($"=== Empleados cargados: {empleados.Count} ===");
            foreach (var emp in empleados)
            {
                Console.WriteLine($"ID: {emp.codigoEmpleado}, Nombre: {emp.nombre} {emp.apellido}, usuarioId: {emp.usuarioId}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando empleados: {ex.Message}");
        }
    }

    // Carga la lista de usuarios
    private async Task CargarUsuarios()
    {
        try
        {
            usuarios = await UserService.GetUsersAsync();
        }
        catch (Exception ex)
        {
            mensaje = $"Error al cargar usuarios: {ex.Message}";
            esError = true;
        }

        // Solo para ver en consola
        Console.WriteLine($"Empleados disponibles: {empleadosDisponibles.Count}");
    }

    // Guarda o actualiza un usuario
    private async Task GuardarUsuario()
    {
        // Validaciones básicas
        if (string.IsNullOrWhiteSpace(userForm.login))
        {
            mensaje = "El nombre de usuario es requerido";
            esError = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(userForm.email))
        {
            mensaje = "El email es requerido";
            esError = true;
            return;
        }

        if (!editando && string.IsNullOrWhiteSpace(userForm.password))
        {
            mensaje = "La contraseña es requerida";
            esError = true;
            return;
        }

        // Configura datos del usuario
        userForm.authorities = new List<string> { rolSeleccionado };
        userForm.langKey = "es";
        userForm.activated = true;

        try
        {
            // ===== EDITAR USUARIO =====
            if (editando && usuarioEditando != null)
            {
                // Crea objeto con datos actualizados
                var userToUpdate = new JhiUser
                {
                    id = usuarioEditando.id,
                    login = userForm.login,
                    firstName = userForm.firstName,
                    lastName = userForm.lastName,
                    email = userForm.email,
                    activated = userForm.activated,
                    langKey = userForm.langKey,
                    authorities = userForm.authorities
                };

                var ok = await UserService.UpdateUserAsync(userToUpdate);

                if (ok)
                {
                    // Vincula empleado si se seleccionó
                    if (empleadoSeleccionadoId.HasValue)
                    {
                        await EmpleadoService.UpdateEmpleadoUsuarioIdAsync(empleadoSeleccionadoId.Value, usuarioEditando.id);
                    }

                    // Quita vínculo anterior si cambió
                    var empAnterior = empleados.FirstOrDefault(e => e.usuarioId == usuarioEditando.id);
                    if (empAnterior != null && empAnterior.codigoEmpleado != empleadoSeleccionadoId)
                    {
                        await EmpleadoService.UpdateEmpleadoUsuarioIdAsync(empAnterior.codigoEmpleado!.Value, null);
                    }

                    mensaje = "Usuario actualizado correctamente";
                    esError = false;

                    await CargarUsuarios();
                    await CargarEmpleados();

                    CancelarEdicion();
                }
                else
                {
                    mensaje = "Error al actualizar usuario";
                    esError = true;
                }
            }
            // ===== CREAR USUARIO =====
            else
            {
                var nuevo = await UserService.CreateUserAsync(userForm);

                if (nuevo != null)
                {
                    // Vincula empleado si se seleccionó
                    if (empleadoSeleccionadoId.HasValue)
                    {
                        await EmpleadoService.UpdateEmpleadoUsuarioIdAsync(empleadoSeleccionadoId.Value, nuevo.id);
                    }

                    mensaje = "Usuario creado correctamente";
                    esError = false;

                    await CargarUsuarios();
                    await CargarEmpleados();

                    LimpiarFormulario();
                }
                else
                {
                    mensaje = "Error al crear usuario";
                    esError = true;
                }
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error: {ex.Message}";
            esError = true;
        }
    }

    // Cambia la contraseña de un usuario
    private async Task CambiarPassword()
    {
        if (string.IsNullOrWhiteSpace(nuevaPassword))
        {
            mensaje = "Ingrese una nueva contraseña";
            esError = true;
            return;
        }

        if (usuarioEditando == null)
            return;

        var ok = await UserService.ChangePasswordAsync(usuarioEditando.login, nuevaPassword);

        if (ok)
        {
            mensaje = "Contraseña cambiada correctamente";
            esError = false;
            nuevaPassword = "";
        }
        else
        {
            mensaje = "Error al cambiar contraseña";
            esError = true;
        }
    }

    // Carga los datos de un usuario para editarlo
    private void EditarUsuario(JhiUser user)
    {
        usuarioEditando = user;

        userForm = new JhiUserCreateDto
        {
            login = user.login,
            firstName = user.firstName,
            lastName = user.lastName,
            email = user.email,
            activated = user.activated,
            langKey = user.langKey,
            authorities = user.authorities
        };

        // Selecciona su rol
        rolSeleccionado = user.authorities.FirstOrDefault() ?? "ROLE_ADMIN";

        // Busca empleado vinculado
        var empAsociado = empleados.FirstOrDefault(e => e.usuarioId == user.id);
        empleadoSeleccionadoId = empAsociado?.codigoEmpleado;

        editando = true;
        nuevaPassword = "";
        mensaje = "";
    }

    // Cancela la edición
    private void CancelarEdicion()
    {
        LimpiarFormulario();
        editando = false;
        usuarioEditando = null;
        mensaje = "";
    }

    // Limpia el formulario
    private void LimpiarFormulario()
    {
        userForm = new();
        rolSeleccionado = "ROLE_ADMIN";
        empleadoSeleccionadoId = null;
        nuevaPassword = "";
    }

    // Elimina un usuario
    private async Task EliminarUsuario(string login)
    {
        // Pide confirmación
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar usuario '{login}'?"))
            return;

        var ok = await UserService.DeleteUserAsync(login);

        if (ok)
        {
            mensaje = "Usuario eliminado correctamente";
            esError = false;

            await CargarUsuarios();
            await CargarEmpleados();

            // Si estabas editando ese usuario, cancela
            if (editando && usuarioEditando?.login == login)
                CancelarEdicion();
        }
        else
        {
            mensaje = "Error al eliminar usuario";
            esError = true;
        }
    }

    // Devuelve estilos según el rol
    private string ObtenerEstiloRol(string rol)
    {
        if (rol == "ROLE_ADMIN")
            return "...";

        if (rol == "ROLE_CHEF")
            return "...";

        return "...";
    }

    // Convierte el rol a texto más entendible
    private string FormatearRol(string rol)
    {
        return rol switch
        {
            "ROLE_ADMIN" => "Administrador",
            "ROLE_CHEF" => "Chef",
            "ROLE_MOZO" => "Mozo",
            _ => rol.Replace("ROLE_", "")
        };
    }

    // Regresa al dashboard
    private void Volver() => Navigation.NavigateTo("/admin/dashboard");

    // Cierra sesión
    private async Task CerrarSesion()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }
}