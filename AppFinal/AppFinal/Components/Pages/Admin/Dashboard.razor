@page "/admin/dashboard"
@inject NavigationManager Navigation
@inject AuthService AuthService
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PaginaProtegida RolRequerido="ADMIN">
    <div style="min-height:100vh; background:#f6f8fb; padding:32px 20px;">
        <div style="max-width:1150px; margin:0 auto;">

            <!-- Header -->
            <div style="display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:24px;">
                <div>
                    <p style="margin:0; font-size:13px; font-weight:700; letter-spacing:1px; color:#6b7280; text-transform:uppercase;">
                        Panel Administrativo
                    </p>
                    <h1 style="margin:6px 0 4px; font-size:36px; font-weight:800; color:#111827;">
                        Dashboard Admin
                    </h1>
                    <p style="margin:0; font-size:15px; color:#6b7280;">
                        Bienvenido, <span style="font-weight:700; color:#374151;">@nombreUsuario</span>
                    </p>
                </div>

                <button @onclick="CerrarSesion"
                        style="padding:12px 18px; background:#fff1f2; color:#be123c; border:1px solid #fecdd3; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer;">
                    Cerrar sesión
                </button>
            </div>

            <!-- Resumen -->
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:16px; margin-bottom:26px;">
                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Acceso</p>
                    <p style="margin:0; font-size:18px; font-weight:800; color:#111827;">Administrador</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Módulos</p>
                    <p style="margin:0; font-size:18px; font-weight:800; color:#111827;">4 disponibles</p>
                </div>

                <div style="background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px 20px; box-shadow:0 6px 18px rgba(15,23,42,0.05);">
                    <p style="margin:0 0 8px; font-size:12px; color:#9ca3af; text-transform:uppercase; letter-spacing:0.8px;">Sistema</p>
                    <p style="margin:0; font-size:18px; font-weight:800; color:#111827;">Gestión restaurante</p>
                </div>
            </div>

            <!-- Módulos -->
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:18px;">

                <div @onclick="IrATurnos"
                     style="background:white; border:1px solid #e5e7eb; border-radius:20px; padding:24px; cursor:pointer; box-shadow:0 8px 24px rgba(15,23,42,0.05); transition:0.2s;">
                    <div style="width:56px; height:56px; border-radius:16px; background:#eef2ff; display:flex; align-items:center; justify-content:center; font-size:28px; margin-bottom:16px;">
                        🕐
                    </div>
                    <p style="margin:0 0 6px; font-size:20px; font-weight:800; color:#111827;">Turnos</p>
                    <p style="margin:0; font-size:14px; color:#6b7280; line-height:1.5;">
                        Administra la asignación de turnos y horarios del personal.
                    </p>
                </div>

                <div @onclick="IrAEmpleados"
                     style="background:white; border:1px solid #e5e7eb; border-radius:20px; padding:24px; cursor:pointer; box-shadow:0 8px 24px rgba(15,23,42,0.05); transition:0.2s;">
                    <div style="width:56px; height:56px; border-radius:16px; background:#ecfeff; display:flex; align-items:center; justify-content:center; font-size:28px; margin-bottom:16px;">
                        👥
                    </div>
                    <p style="margin:0 0 6px; font-size:20px; font-weight:800; color:#111827;">Empleados</p>
                    <p style="margin:0; font-size:14px; color:#6b7280; line-height:1.5;">
                        Registra, edita y controla la información del personal.
                    </p>
                </div>

                <div @onclick="IrAUsuarios"
                     style="background:white; border:1px solid #e5e7eb; border-radius:20px; padding:24px; cursor:pointer; box-shadow:0 8px 24px rgba(15,23,42,0.05); transition:0.2s;">
                    <div style="width:56px; height:56px; border-radius:16px; background:#f5f3ff; display:flex; align-items:center; justify-content:center; font-size:28px; margin-bottom:16px;">
                        👤
                    </div>
                    <p style="margin:0 0 6px; font-size:20px; font-weight:800; color:#111827;">Usuarios</p>
                    <p style="margin:0; font-size:14px; color:#6b7280; line-height:1.5;">
                        Gestiona cuentas del sistema, roles y accesos.
                    </p>
                </div>

                <div @onclick="IrACarta"
                     style="background:white; border:1px solid #e5e7eb; border-radius:20px; padding:24px; cursor:pointer; box-shadow:0 8px 24px rgba(15,23,42,0.05); transition:0.2s;">
                    <div style="width:56px; height:56px; border-radius:16px; background:#fff7ed; display:flex; align-items:center; justify-content:center; font-size:28px; margin-bottom:16px;">
                        🍴
                    </div>
                    <p style="margin:0 0 6px; font-size:20px; font-weight:800; color:#111827;">Carta</p>
                    <p style="margin:0; font-size:14px; color:#6b7280; line-height:1.5;">
                        Organiza categorías, platos, precios y disponibilidad.
                    </p>
                </div>

            </div>
        </div>
    </div>
</PaginaProtegida>

@code {
    // Nombre que se mostrará en el dashboard
    private string nombreUsuario = "Administrador";

    // Variable para evitar que el código se ejecute varias veces
    private bool inicializado = false;

    // Este método se ejecuta después de que la página se renderiza
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Si no es la primera vez o ya se ejecutó antes, no hace nada
        if (!firstRender || inicializado)
            return;

        // Marca que ya se ejecutó
        inicializado = true;

        // Obtiene el nombre del usuario desde el servicio
        nombreUsuario = await AuthService.ObtenerUsuario() ?? "Administrador";

        // Actualiza la pantalla con el nuevo nombre
        StateHasChanged();
    }

    // Método para cerrar sesión
    private async Task CerrarSesion()
    {
        await AuthService.Logout(); // Cierra la sesión
        Navigation.NavigateTo("/login"); // Redirige al login
    }

    // Métodos para navegar a cada módulo

    private void IrATurnos()
        => Navigation.NavigateTo("/admin/empleado-turnos"); // Va a turnos

    private void IrAEmpleados()
        => Navigation.NavigateTo("/admin/empleados"); // Va a empleados

    private void IrAUsuarios()
        => Navigation.NavigateTo("/admin/usuarios"); // Va a usuarios

    private void IrACarta()
        => Navigation.NavigateTo("/admin/carta"); // Va a carta (menú)
}